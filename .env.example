# Copy this file to .env, set every blank value, then run:
# python scripts/validate_env.py && docker compose up
# DATABASE_URL must use the Docker service hostname, for example:
# postgresql+psycopg://rag:<password>@postgres:5432/rag
POSTGRES_USER=rag
POSTGRES_DB=rag
POSTGRES_PASSWORD=
DATABASE_URL=
MINIO_ROOT_USER=rag
MINIO_ROOT_PASSWORD=
JWT_SECRET=
# Use local-byte offline, or set an absolute path to a provisioned tokenizer.json.
EMBEDDING_TOKENIZER=local-byte
EMBEDDING_MAX_TOKENS=32768
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=50
OCR_LANGUAGES=eng+vie
OCR_DPI=300
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_DB=langfuse
LANGFUSE_POSTGRES_PASSWORD=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_CLICKHOUSE_USER=langfuse
LANGFUSE_CLICKHOUSE_PASSWORD=
# Optional project keys generated by the local Langfuse instance. Traces contain
# only route, hashed workspace ID, model IDs, status, and latency.
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
